---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL, LINKEDIN_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { withBase } from '../utils/base';

const skills = ['CUDA', 'GPU Architecture', 'C++', 'Python', 'PyTorch'];
const learning = ['CUTLASS', 'Triton'];

const projects = [
	{
		title: 'CUDA Performance Engineering',
		description:
			'Matrix-multiplication kernels on the GPU, optimized stage by stage: naive → shared-memory tiling → 1D register tiling → 2D register tiling.',
		href: 'https://github.com/AvinashQtC/cuda-performance-engineering',
		linkLabel: 'View on GitHub',
		writeup: withBase('/blog/optimizing-cuda-matmul/'),
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Avinash Singh</h1>
				<p class="tagline">Quantum Researcher — GPU Performance Engineering</p>
				<p class="bio">
					I work on matmul optimization and GPU performance engineering, digging into how matrix
					multiplication actually runs on hardware — from naive kernels down to register-tiled,
					memory-hierarchy-aware CUDA GEMMs.
				</p>
				<div class="links">
					<a class="button" href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
					<a class="button" href={LINKEDIN_URL} target="_blank" rel="noopener">LinkedIn</a>
				</div>
			</section>

			<section class="skills">
				<h2>Skills</h2>
				<ul class="chips">
					{skills.map((skill) => <li>{skill}</li>)}
				</ul>
				<p class="learning">
					Currently learning:
					<ul class="chips">
						{learning.map((skill) => <li>{skill}</li>)}
					</ul>
				</p>
			</section>

			<section class="projects">
				<h2>Projects</h2>
				{
					projects.map((project) => (
						<article class="project-card">
							<h3>{project.title}</h3>
							<p>{project.description}</p>
							<div class="project-links">
								<a href={project.href} target="_blank" rel="noopener">
									{project.linkLabel}
								</a>
								{project.writeup && <a href={project.writeup}>Read the write-up</a>}
							</div>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 3em;
	}
	.tagline {
		font-size: 1.25em;
		font-weight: 700;
		color: var(--accent);
		margin-bottom: 0.75em;
	}
	.bio {
		max-width: 60ch;
	}
	.links {
		display: flex;
		gap: 1em;
		margin-top: 1.5em;
	}
	.button {
		display: inline-block;
		padding: 0.6em 1.4em;
		border: 2px solid var(--accent);
		border-radius: 8px;
		color: var(--accent);
		text-decoration: none;
		font-weight: 700;
	}
	.button:hover {
		background: var(--accent);
		color: white;
	}

	.skills,
	.projects {
		margin-bottom: 3em;
	}
	.chips {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6em;
		margin: 0.75em 0 0 0;
		padding: 0;
	}
	.chips li {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		padding: 0.35em 0.9em;
		border-radius: 999px;
		font-size: 0.9em;
	}
	.learning {
		margin-top: 1.25em;
	}

	.project-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 1.5em;
		box-shadow: var(--box-shadow);
	}
	.project-card h3 {
		margin-bottom: 0.4em;
	}
	.project-links {
		display: flex;
		gap: 1.5em;
		margin-top: 1em;
		font-weight: 700;
	}
</style>
